
{% if template == 'product' and product.metafields.custom.pay_your_price %}

  <form method="post" action="/cart/add" id="pay-your-price-form" style="width: max-content; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto;">
    <!-- Hidden input for product variant ID -->
    <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
    <input type="hidden" name="properties[__isValid]" value="{{ product.metafields.custom.pay_your_price}}" />


    <!-- Custom price input -->
    <input 
      type="number" 
      id="price-input" 
      style="max-width:250px; outline:auto" 
      class="product-form__submit button button--full-width button--secondary"
      name="properties[__custom_price]" 
      placeholder="Enter your price" 
      step="0.01" 
    />
    <div class="payyourprice-form__error-message-wrapper" role="alert" hidden>
      <span class="svg-wrapper">
        <svg class="icon icon-error" viewBox="0 0 13 13">
          <circle cx="6.5" cy="6.5" r="5.5" stroke="#fff" stroke-width="2"></circle>
          <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width=".7"></circle>
          <path fill="#fff" d="m5.874 3.528.1 4.044h1.053l.1-4.044zm.627 6.133c.38 0 .68-.288.68-.656s-.3-.656-.68-.656-.681.288-.681.656.3.656.68.656"></path>
        </svg>
      </span>
      <span class="payyourprice-form__error-message"></span>
    </div>
    
    <button type="submit" id="appcart_button" style="width:max-content; min-width:250px; " class="product-form__submit button button--full-width button--secondary">Add to cart</button>
  
    </form>
{% endif %}

<script>
document.addEventListener("DOMContentLoaded", () => {
  const template = "{{ template }}";
  var payYourPrice = "{{ product.metafields.custom.pay_your_price}}"
  console.log(template)
  // Common DOM Elements
  const form = document.getElementById("pay-your-price-form");
  const priceInput = document.getElementById("price-input");
  const errorMessageWrapper = document.querySelector(".payyourprice-form__error-message-wrapper");
  const errorMessage = document.querySelector(".payyourprice-form__error-message");
const isValid = {% if product.metafields.custom.pay_your_price == true %} true {% else %} false {% endif %};
console.log("Product is valid", isValid);
  // Error handling function
  function showError(message) {
    errorMessage.textContent = message;
    errorMessageWrapper.hidden = false;
  }

  // Check for Cart Page
  // if (template === 'cart') {
  
  //   const oldPrices = document.getElementsByClassName("cart-item__discounted-prices");
  //   const oldPrice = document.getElementsByClassName("product-option");
  //   Array.from(oldPrice).forEach(price => price.innerHTML = 1000);


  //   Array.from(oldPrices).forEach(price => price.style.display = 'none');
  // }
//   if (template === "collection") {


//   let forms = document.getElementsByClassName("form");

//   // Update the action attribute for each form
//   for (let formElement of forms) {
//     formElement.style.display = "none";
//   }
// }


  // Check for Product Page
  if (template === 'product' && payYourPrice !== null && payYourPrice !== undefined && payYourPrice === true) {


    console.log("This is not a valid pay your price product")
    document.getElementsByClassName("product-form__quantity")[0].style.display = "none";
    console.log("IsValid", isValid);
    console.log("Pay your price:", payYourPrice);
    const shareButton = document.querySelector("share-button");
    if(shareButton && !payYourPrice){
      shareButton.parentNode.insertBefore(form, shareButton);

    document.getElementsByTagName("product-form")[0].style.display = "none";

    const officialPrice = document.querySelector(".price-item");
    const maxPrice = parseFloat("{{ product.price | divided_by: 100 }}");
    const displayMaxPrice = "{{ product.price | money }}";
    const displayMinPrice = "{{ product.metafields.custom.default_price | times: 100 | money }}";
    const defaultPrice = "{% if product.metafields.custom.default_price %}{{ product.metafields.custom.default_price }}{% else %}null{% endif %}";

    // Handle default price validation
    if (defaultPrice) {
      officialPrice.innerHTML = `${displayMinPrice} - ${displayMaxPrice}`;
      form.addEventListener("submit", (event) => {
        const inputValue = parseFloat(priceInput.value);
        
        if (isNaN(inputValue) || inputValue < defaultPrice || inputValue > maxPrice) {
          event.preventDefault();
          showError(`Please enter a price between ${displayMinPrice} and ${displayMaxPrice}.`);
        } else {
          errorMessageWrapper.hidden = true;
        }
      });
 } 
    }
 
      
}}
);
</script>

{% schema %}
{
  "name": "Price Input Block",
  "target": "body",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    }
  ]
}
{% endschema %}